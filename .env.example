# Proxmox Configuration
PROXMOX_HOST=https://192.168.1.100:8006
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=dashboard
PROXMOX_TOKEN_VALUE=your-token-here
PROXMOX_VERIFY_SSL=false

# Docker Configuration
# DOCKER_GID: Host Docker group ID so the container can read the socket.
# Find it with: stat -c '%g' /var/run/docker.sock
DOCKER_GID=996
# DOCKER_URL: Base URL for clickable container links in the dashboard (optional)
DOCKER_URL=http://192.168.1.100

# Radarr Configuration
RADARR_URL=http://192.168.1.100:7878
RADARR_API_KEY=your-radarr-api-key

# Sonarr Configuration
SONARR_URL=http://192.168.1.100:8989
SONARR_API_KEY=your-sonarr-api-key

# Lidarr Configuration (optional)
LIDARR_URL=http://192.168.1.100:8686
LIDARR_API_KEY=your-lidarr-api-key

# Jellyfin Configuration (optional — for streaming sessions)
JELLYFIN_URL=http://192.168.1.100:8096
JELLYFIN_API_KEY=your-jellyfin-api-key

# Plex Configuration (optional — for streaming sessions)
# Use either Plex direct OR Tautulli, not both (to avoid duplicate sessions)
PLEX_URL=http://192.168.1.100:32400
PLEX_TOKEN=your-plex-token

# Tautulli Configuration (optional — richer Plex streaming info)
TAUTULLI_URL=http://192.168.1.100:8181
TAUTULLI_API_KEY=your-tautulli-api-key

# Claude AI Chat (optional)
CLAUDE_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-20250514

# Uptime Kuma (optional — monitoring dashboard)
UPTIME_KUMA_URL=http://192.168.1.100:3001

# Infrastructure Monitoring (optional — SSL cert tracking via NPM)
NPM_URL=http://192.168.1.100:81
NPM_API_TOKEN=your-npm-jwt-token

# Notifications (optional — Telegram alerts)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Dashboard Settings
REFRESH_INTERVAL=30

# Authentication (optional — auto-generated if not set, but sessions reset on restart)
JWT_SECRET=your-random-secret-here
